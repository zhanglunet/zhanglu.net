---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import aboutZh from '../data/about.json';
import aboutEn from '../data/about.en.json';
import { getLangFromUrl, altPath } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const about = lang === 'en' ? aboutEn : aboutZh;

const fullTitle = title ? `${title} · ${about.name}` : `${about.name} — ${about.tagline}`;
const desc = description ?? about.bio;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : undefined;
const zhHref = new URL(altPath(Astro.url.pathname, 'zh'), Astro.site);
const enHref = new URL(altPath(Astro.url.pathname, 'en'), Astro.site);
const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={about.name} href={lang === 'en' ? '/en/rss.xml' : '/rss.xml'} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh-CN" href={zhHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={zhHref} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'zh_CN'} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <script is:inline>
      // First visit: adapt to the browser language. After a manual switch, remember the choice and stop auto-redirecting.
      (function () {
        try {
          var p = location.pathname;
          var cur = (p === '/en' || p.indexOf('/en/') === 0) ? 'en' : 'zh';
          var stored = localStorage.getItem('site-lang');
          var want = stored || (/^en\b/i.test(navigator.language || '') ? 'en' : 'zh');
          if (want !== cur) {
            var alt = cur === 'en'
              ? (p.replace(/^\/en/, '') || '/')
              : (p === '/' ? '/en/' : '/en' + p);
            if (alt !== p) location.replace(alt + location.search + location.hash);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 w-full max-w-4xl mx-auto px-6 py-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>

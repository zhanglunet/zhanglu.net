---
import aboutZh from '../data/about.json';
import aboutEn from '../data/about.en.json';
import { getLangFromUrl, localizePath, altPath, stripLang } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const about = lang === 'en' ? aboutEn : aboutZh;
const here = stripLang(Astro.url.pathname);

const nav = [
  { base: '/', key: 'nav.home' as const },
  { base: '/projects', key: 'nav.projects' as const },
  { base: '/c-suite', key: 'nav.csuite' as const },
  { base: '/presentations', key: 'nav.presentations' as const },
  { base: '/articles', key: 'nav.writing' as const },
  { base: '/weekly', key: 'nav.weekly' as const },
  { base: '/skills', key: 'nav.skills' as const },
  { base: '/agents', key: 'nav.agents' as const },
  { base: '/about', key: 'nav.about' as const },
];
const isActive = (base: string) => (base === '/' ? here === '/' : here.startsWith(base));

const target = lang === 'en' ? 'zh' : 'en';
const toggleHref = altPath(Astro.url.pathname, target);
const homeHref = localizePath('/', lang);
---
<header class="border-b border-[var(--color-rule)] bg-[var(--color-paper)]">
  <div class="max-w-4xl mx-auto px-6 py-5 flex items-center justify-between flex-wrap gap-4">
    <a href={homeHref} class="flex items-center gap-2 font-serif text-xl font-semibold tracking-tight shrink-0">
      <img src="/brand/zhanglu-mark.svg" alt="" class="w-6 h-6" />
      <span>{about.name}<span class="text-[var(--color-accent)]">.</span></span>
    </a>
    <nav class="flex items-center gap-4 sm:gap-5 text-sm max-w-full overflow-x-auto whitespace-nowrap [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
      {nav.map((item) => (
        <a
          href={localizePath(item.base, lang)}
          class:list={[
            'transition-colors shrink-0',
            isActive(item.base)
              ? 'text-[var(--color-ink)] font-medium'
              : 'text-[var(--color-muted)] hover:text-[var(--color-ink)]',
          ]}
        >
          {t(item.key)}
        </a>
      ))}
      <a
        id="lang-toggle"
        data-target-lang={target}
        href={toggleHref}
        aria-label={t('toggle.aria')}
        class="shrink-0 ml-1 px-2 py-0.5 rounded border border-[var(--color-rule)] text-[var(--color-muted)] hover:text-[var(--color-ink)] hover:border-[var(--color-ink)] transition-colors font-mono text-xs"
      >
        {t('toggle.label')}
      </a>
    </nav>
  </div>
</header>
<script is:inline>
  (function () {
    var el = document.getElementById('lang-toggle');
    if (el) el.addEventListener('click', function () {
      try { localStorage.setItem('site-lang', el.getAttribute('data-target-lang')); } catch (e) {}
    });
  })();
</script>

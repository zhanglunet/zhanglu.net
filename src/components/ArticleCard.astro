---
import type { CollectionEntry } from 'astro:content';
interface Props { entry: CollectionEntry<'articles'> }
const { entry } = Astro.props;
const { title, summary, url, date, source, tags } = entry.data;
const dateStr = date.toISOString().slice(0, 10);
const sourceLabel: Record<string, string> = {
  wechat: '公众号', substack: 'Substack', blog: '博客', x: 'X', other: '其它',
};
const siteOrigin = Astro.site?.origin ?? 'https://zhanglu.net';
const isInternal = url.startsWith(siteOrigin) || url.startsWith('/');
const displayHref = isInternal && url.startsWith(siteOrigin)
  ? url.slice(siteOrigin.length) || '/'
  : url;
---
<article class="border-b border-[var(--color-rule)] py-5 last:border-b-0">
  <div class="flex items-baseline gap-3 text-xs text-[var(--color-muted)] mb-1.5">
    <time>{dateStr}</time>
    <span>·</span>
    <span>{isInternal ? '站内' : (sourceLabel[source] ?? source)}</span>
  </div>
  <h3 class="font-serif text-lg font-semibold mb-1.5">
    <a
      href={displayHref}
      class="hover:text-[var(--color-accent)]"
      {...(isInternal ? {} : { target: '_blank', rel: 'noopener' })}
    >
      {title}
    </a>
  </h3>
  <p class="text-sm text-[var(--color-muted)] leading-relaxed">{summary}</p>
  {tags.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1.5 text-xs text-[var(--color-muted)]">
      {tags.map((t) => <span>#{t}</span>)}
    </div>
  )}
</article>

---
import socialZh from '../data/social.json';
import socialEn from '../data/social.en.json';
import { getLangFromUrl } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const links = (lang === 'en' ? socialEn : socialZh).links;
---
<ul class="space-y-4">
  {links.map((l) => (
    <li class="flex items-start gap-3 text-sm">
      <span class="font-mono text-[var(--color-muted)] w-20 shrink-0 pt-0.5">{l.label}</span>
      <div class="flex-1">
        {l.url && !l.url.includes('TODO') ? (
          <a href={l.url} class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">
            {l.handle}
          </a>
        ) : l.qrcode ? (
          <details class="group">
            <summary class="cursor-pointer text-[var(--color-accent)] hover:underline list-none">
              {l.handle} <span class="text-xs text-[var(--color-muted)] group-open:hidden">{t('social.qropen')}</span><span class="text-xs text-[var(--color-muted)] hidden group-open:inline">{t('social.qrclose')}</span>
            </summary>
            <img src={l.qrcode} alt={t('social.qralt', { x: l.label })} width="180" height="180" class="mt-3 rounded border border-[var(--color-rule)]" />
          </details>
        ) : (
          <span class="text-[var(--color-muted)]">{l.handle}</span>
        )}
      </div>
    </li>
  ))}
</ul>

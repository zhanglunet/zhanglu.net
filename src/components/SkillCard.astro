---
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, localizePath } from '../i18n/utils';
interface Props { entry: CollectionEntry<'skills'> | CollectionEntry<'skillsEn'> }
const { entry } = Astro.props;
const { name, description, featured, handwritten } = entry.data;
const lang = getLangFromUrl(Astro.url);
const skillHref = localizePath(`/skills/${entry.slug}`, lang);
---
<article class="border border-[var(--color-rule)] rounded-md p-4 hover:border-[var(--color-ink)] transition-colors">
  <div class="flex items-start justify-between gap-2 mb-1.5">
    <h3 class="font-mono text-sm font-semibold">
      <a href={skillHref} class="hover:text-[var(--color-accent)]">
        /{name}
      </a>
    </h3>
    {(featured || handwritten) && (
      <span class="text-[10px] uppercase tracking-wider text-[var(--color-accent)]">
        {featured ? '★' : ''}{handwritten ? '✎' : ''}
      </span>
    )}
  </div>
  <p class="text-xs text-[var(--color-muted)] leading-relaxed line-clamp-4 whitespace-pre-line wrap-anywhere">{description}</p>
</article>

---
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, localizePath } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
interface Props { entry: CollectionEntry<'projects'> | CollectionEntry<'projectsEn'> }
const { entry } = Astro.props;
const { title, tagline, url, tech, year, status, loc, persona, cover } = entry.data;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const detailHref = localizePath(`/projects/${entry.slug}`, lang);
---
<article class="group border border-[var(--color-rule)] rounded-md overflow-hidden hover:border-[var(--color-ink)] transition-colors bg-white/40">
  {cover && (
    <a href={detailHref} class="block aspect-[16/9] overflow-hidden bg-[var(--color-paper-2)] border-b border-[var(--color-rule)]">
      <img
        src={cover}
        alt={t('card.shot', { x: title })}
        loading="lazy"
        class="w-full h-full object-cover object-top group-hover:scale-[1.015] transition-transform duration-300"
      />
    </a>
  )}
  <div class="p-5">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="font-serif text-lg font-semibold">
        <a href={detailHref} class="hover:text-[var(--color-accent)]">{title}</a>
      </h3>
      <span class="text-xs text-[var(--color-muted)] shrink-0">{year}</span>
    </div>
    {persona && (
      <p class="mb-2">
        <span class="inline-block px-2 py-0.5 text-xs rounded bg-[var(--color-paper-2)] text-[var(--color-accent)] font-medium">{t('card.builtFor', { x: persona })}</span>
      </p>
    )}
    <p class="text-[var(--color-muted)] text-sm leading-relaxed mb-3">{tagline}</p>
    <div class="flex flex-wrap items-center gap-2 text-xs">
      {tech.slice(0, 4).map((t) => (
        <span class="px-2 py-0.5 bg-[var(--color-paper-2)] rounded">{t}</span>
      ))}
      {status !== 'live' && (
        <span class="px-2 py-0.5 border border-[var(--color-rule)] rounded text-[var(--color-muted)]">{status}</span>
      )}
      {loc && (
        <span class="ml-auto font-mono text-[var(--color-muted)]" title={t('card.locTitle')}>{t('card.loc', { x: loc.toLocaleString() })}</span>
      )}
    </div>
    <div class="mt-4 flex gap-4 text-sm">
      {url && (
        <a href={url} class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">
          {t('common.visit')}
        </a>
      )}
      <a href={detailHref} class="text-[var(--color-muted)] hover:text-[var(--color-ink)]">{t('common.details')}</a>
    </div>
  </div>
</article>

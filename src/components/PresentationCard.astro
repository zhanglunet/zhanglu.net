---
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
interface Props { entry: CollectionEntry<'presentations'> | CollectionEntry<'presentationsEn'> }
const { entry } = Astro.props;
const { title, tagline, url, kind, year } = entry.data;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const kindLabel = kind === 'slides' ? t('pres.deck') : t('pres.site');
let host = url;
try { host = new URL(url).host.replace(/^www\./, ''); } catch {}
---
<article class="group border border-[var(--color-rule)] rounded-md p-5 hover:border-[var(--color-ink)] transition-colors bg-white/40">
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="font-serif text-lg font-semibold">
      <a href={url} class="hover:text-[var(--color-accent)]" target="_blank" rel="noopener">{title}</a>
    </h3>
    <span class="text-xs text-[var(--color-muted)] shrink-0">{year}</span>
  </div>
  <p class="text-[var(--color-muted)] text-sm leading-relaxed mb-3 whitespace-pre-line">{tagline}</p>
  <div class="flex flex-wrap items-center gap-2 text-xs">
    <span class="px-2 py-0.5 bg-[var(--color-paper-2)] rounded">{kindLabel}</span>
    <span class="text-[var(--color-muted)]">{host}</span>
  </div>
  <div class="mt-4 flex gap-4 text-sm">
    <a href={url} class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">
      {t('common.open')}
    </a>
  </div>
</article>

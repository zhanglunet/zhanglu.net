---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = (await getCollection('articles', ({ id }) => id !== 'README.md'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base title="文章" description="公众号 / 博客文章索引">
  <h1 class="font-serif text-3xl font-semibold mb-2">文章</h1>
  <p class="text-[var(--color-muted)] mb-8">公众号 / Substack / 博客的文章索引，共 {articles.length} 篇。</p>
  {articles.length === 0 ? (
    <p class="text-[var(--color-muted)]">还没有文章。新增见 <code>AGENTS.md</code>。</p>
  ) : (
    <div>
      {articles.map((a) => <ArticleCard entry={a} />)}
    </div>
  )}
</Base>

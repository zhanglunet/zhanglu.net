---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = (await getCollection('articles', ({ id }) => id !== 'README.md'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base title="文章" description="写作索引：站内长文 + 外部博客 / 公众号">
  <h1 class="font-serif text-3xl font-semibold mb-2">文章</h1>
  <p class="text-[var(--color-muted)] mb-8">
    写作索引，共 {articles.length} 篇。链接指向原始出处 ——
    站内 <a href="/posts" class="text-[var(--color-accent)] underline underline-offset-4">posts</a> 或外部博客 / 公众号。
  </p>
  {articles.length === 0 ? (
    <p class="text-[var(--color-muted)]">还没有文章。新增见 <code>AGENTS.md</code>。</p>
  ) : (
    <div>
      {articles.map((a) => <ArticleCard entry={a} />)}
    </div>
  )}
</Base>

---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import SkillCard from '../../../components/SkillCard.astro';

const skills = (await getCollection('skillsEn'))
  .sort((a, b) => {
    const aw = (a.data.featured ? 2 : 0) + (a.data.handwritten ? 1 : 0);
    const bw = (b.data.featured ? 2 : 0) + (b.data.handwritten ? 1 : 0);
    if (aw !== bw) return bw - aw;
    return a.data.name.localeCompare(b.data.name);
  });
---
<Base title="Skills" description="The Claude Skills I use / built">
  <h1 class="font-serif text-3xl font-semibold mb-2">Skills</h1>
  <p class="text-[var(--color-muted)] mb-8">
    Synced from <code>~/.claude/skills/</code> on my machine — {skills.length} in total.
    ★ marks a pick, ✎ marks a hand-written intro.
  </p>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {skills.map((s) => <SkillCard entry={s} />)}
  </div>
</Base>

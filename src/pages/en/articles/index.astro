---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import ArticleCard from '../../../components/ArticleCard.astro';

const articles = (await getCollection('articlesEn'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base title="Writing" description="A writing index: on-site posts + external blog / WeChat">
  <h1 class="font-serif text-3xl font-semibold mb-2">Writing</h1>
  <p class="text-[var(--color-muted)] mb-8">
    A writing index — {articles.length} entries. Links point to the original source ——
    on-site <a href="/en/posts" class="text-[var(--color-accent)] underline underline-offset-4">posts</a> or external blog / WeChat.
  </p>
  {articles.length === 0 ? (
    <p class="text-[var(--color-muted)]">Nothing here yet.</p>
  ) : (
    <div>
      {articles.map((a) => <ArticleCard entry={a} />)}
    </div>
  )}
</Base>

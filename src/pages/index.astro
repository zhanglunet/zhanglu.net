---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import PresentationCard from '../components/PresentationCard.astro';
import SkillCard from '../components/SkillCard.astro';
import about from '../data/about.json';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const presentations = (await getCollection('presentations'))
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999));

const allArticles = await getCollection('articles');
const recentArticles = allArticles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const allSkills = await getCollection('skills');
const featuredSkills = allSkills
  .filter((s) => s.data.featured || s.data.handwritten)
  .slice(0, 6);
const otherSkills = allSkills
  .filter((s) => !s.data.featured && !s.data.handwritten);

const tui3Sites = [
  { name: '黑板报文艺', years: '1999–2007', img: '/tui3/heibanbao.webp', url: 'https://heibanbao.tui3.com/' },
  { name: '畅游网', years: '1999–2007', img: '/tui3/changyou.webp', url: 'https://changyou.tui3.com/' },
  { name: '在路上', years: '2007', img: '/tui3/zhanglu.webp', url: 'https://zhanglu.tui3.com/' },
  { name: '说3 · 科技TV', years: '2007', img: '/tui3/shuo3.webp', url: 'https://shuo3.tui3.com/' },
  { name: '沙发网', years: '2007', img: '/tui3/sofaee.webp', url: 'https://sofaee.tui3.com/' },
];
---
<Base image="/og/home.png">
  <section class="py-10 sm:py-16">
    <div class="road-flow flex items-center gap-2 mb-4 max-w-md sm:max-w-lg" role="img" aria-label="一条路流进「张路」，一个句点收尾">
      <div class="flex-1 min-w-0">
        <svg viewBox="0 0 340 110" preserveAspectRatio="xMaxYMid meet" class="block w-full h-auto">
          <path class="road" d="M 0 55 L 88 18 L 176 90 L 264 22 L 340 55"
            fill="none" stroke="var(--color-ink)" stroke-width="13"
            stroke-linecap="round" stroke-linejoin="round" pathLength="100" />
          <circle class="wp" cx="88" cy="18" r="4.4" fill="var(--color-paper)" />
          <circle class="wp" cx="176" cy="90" r="4.4" fill="var(--color-paper)" />
          <circle class="wp" cx="264" cy="22" r="4.4" fill="var(--color-paper)" />
        </svg>
      </div>
      <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight whitespace-nowrap shrink-0">
        {about.name}<span class="hero-period text-[var(--color-accent)]">.</span>
      </h1>
    </div>
    <p class="font-serif text-xl sm:text-2xl text-[var(--color-ink)] mb-6 leading-snug">
      {about.tagline}
    </p>
    <p class="text-[var(--color-muted)] max-w-2xl leading-relaxed">
      {about.bio}
    </p>
    <div class="mt-6 flex flex-wrap gap-2">
      {about.tags.map((t) => (
        <span class="text-xs px-2 py-1 bg-[var(--color-paper-2)] rounded font-mono">{t}</span>
      ))}
    </div>
  </section>

  <section class="py-8 border-t border-[var(--color-rule)]">
    <div class="rounded-lg border border-[var(--color-rule)] bg-[var(--color-paper-2)] px-5 py-5 sm:px-6">
      <div class="flex items-baseline justify-between gap-3 mb-1.5">
        <p class="font-serif text-lg sm:text-xl text-[var(--color-ink)]">一套面向 C-suite 的决策智能体</p>
        <a href="/c-suite" class="shrink-0 text-sm text-[var(--color-accent)] hover:underline">了解这套 →</a>
      </div>
      <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-4">
        为 AI 原生组织而设计：把 CEO 的战略判断、CMO 的品牌判断、CFO 的投研判断，各做成一条可调研、可打分、可复盘的流水线。
      </p>
      <div class="flex flex-wrap gap-2 text-sm">
        <a href="/projects/boss" class="inline-flex items-center gap-1 px-3 py-1 rounded-full border border-[var(--color-rule)] bg-white/40 hover:border-[var(--color-accent)] transition-colors">Boss <span class="text-[var(--color-accent)]">· CEO</span></a>
        <a href="/projects/mbabrand" class="inline-flex items-center gap-1 px-3 py-1 rounded-full border border-[var(--color-rule)] bg-white/40 hover:border-[var(--color-accent)] transition-colors">MBA Brand <span class="text-[var(--color-accent)]">· CMO</span></a>
        <a href="/projects/oaf" class="inline-flex items-center gap-1 px-3 py-1 rounded-full border border-[var(--color-rule)] bg-white/40 hover:border-[var(--color-accent)] transition-colors">OAF <span class="text-[var(--color-accent)]">· CFO</span></a>
      </div>
    </div>
  </section>

  <section class="py-8 border-t border-[var(--color-rule)]">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="font-serif text-2xl font-semibold">精选项目</h2>
      <a href="/projects" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)]">全部 →</a>
    </div>
    <div class="grid sm:grid-cols-2 gap-4">
      {featuredProjects.map((p) => <ProjectCard entry={p} />)}
    </div>
  </section>

  {presentations.length > 0 && (
    <section class="py-8 border-t border-[var(--color-rule)]">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="font-serif text-2xl font-semibold">展示</h2>
        <a href="/presentations" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)]">全部 →</a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {presentations.map((p) => <PresentationCard entry={p} />)}
      </div>
    </section>
  )}

  {recentArticles.length > 0 && (
    <section class="py-8 border-t border-[var(--color-rule)]">
      <div class="flex items-baseline justify-between mb-2">
        <h2 class="font-serif text-2xl font-semibold">最近文章</h2>
        <a href="/articles" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)]">全部 →</a>
      </div>
      <div>
        {recentArticles.map((a) => <ArticleCard entry={a} />)}
      </div>
    </section>
  )}

  <section class="py-8 border-t border-[var(--color-rule)]">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="font-serif text-2xl font-semibold">Skills</h2>
      <a href="/skills" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)]">
        全部 {allSkills.length} 个 →
      </a>
    </div>
    {featuredSkills.length > 0 && (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-4">
        {featuredSkills.map((s) => <SkillCard entry={s} />)}
      </div>
    )}
    {otherSkills.length > 0 && (
      <p class="text-sm text-[var(--color-muted)]">
        以及另外 {otherSkills.length} 个 skill：
        {otherSkills.slice(0, 20).map((s, i) => (
          <>
            {i > 0 && <span>, </span>}
            <a href={`/skills/${s.slug}`} class="font-mono hover:text-[var(--color-ink)]">/{s.data.name}</a>
          </>
        ))}
        {otherSkills.length > 20 && <span> …</span>}
      </p>
    )}
  </section>

  <section class="py-8 border-t border-[var(--color-rule)]">
    <div class="flex items-baseline justify-between mb-2">
      <h2 class="font-serif text-2xl font-semibold">往期作品</h2>
      <a href="/projects/tui3" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)]">详情 →</a>
    </div>
    <p class="text-[var(--color-muted)] text-sm mb-6 max-w-2xl">
      在做这些 AI 产品之前——<a href="https://tui3.com" target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline">tui3.com</a> 把我 1999–2007 年间参与的几个中文个人网站，从服务器存档整体重建成静态站，永久保存。
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      {tui3Sites.map((s) => (
        <a href={s.url} target="_blank" rel="noopener" class="group block border border-[var(--color-rule)] rounded-md overflow-hidden hover:border-[var(--color-accent)] transition-colors bg-white/40">
          <div class="aspect-[4/3] overflow-hidden bg-[var(--color-paper-2)]">
            <img src={s.img} alt={`${s.name} 存档截图`} loading="lazy" class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-300" />
          </div>
          <div class="p-2.5">
            <div class="text-xs font-medium leading-tight">{s.name}</div>
            <div class="text-[10px] text-[var(--color-muted)] font-mono mt-0.5">{s.years}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  @keyframes road-draw { to { stroke-dashoffset: 0; } }
  @keyframes road-fade { to { opacity: 1; } }
  @keyframes road-pop { from { opacity: 0; transform: scale(0.3); } to { opacity: 1; transform: scale(1); } }

  .road-flow .road {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: road-draw 1.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .road-flow .wp {
    opacity: 0;
    animation: road-fade 0.5s ease forwards;
    animation-delay: 0.85s;
  }
  .hero-period {
    display: inline-block;
    opacity: 0;
    transform-origin: center;
    animation: road-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    animation-delay: 1.25s;
  }
  @media (prefers-reduced-motion: reduce) {
    .road-flow .road { stroke-dashoffset: 0; animation: none; }
    .road-flow .wp,
    .hero-period { opacity: 1; animation: none; }
  }
</style>

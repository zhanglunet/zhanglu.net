---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const weeklies = (await getCollection('weekly'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base title="周报" description="每周做了什么的公开周报（脱敏版）">
  <h1 class="font-serif text-3xl font-semibold mb-2">周报</h1>
  <p class="text-[var(--color-muted)] mb-8">
    每周做了什么的公开记录（脱敏版），共 {weeklies.length} 篇。
  </p>

  {weeklies.length === 0 ? (
    <p class="text-[var(--color-muted)]">还没有周报。</p>
  ) : (
    <div class="space-y-6">
      {weeklies.map((w) => (
        <a href={`/weekly/${w.slug}`} class="block group p-5 border border-[var(--color-rule)] rounded hover:border-[var(--color-accent)] transition-colors">
          <div class="flex items-baseline justify-between gap-4 mb-2">
            <h2 class="font-serif text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">
              {w.data.title}
            </h2>
            <span class="text-xs font-mono text-[var(--color-muted)] shrink-0">{w.data.week}</span>
          </div>
          <p class="text-xs font-mono text-[var(--color-muted)] mb-2">{w.data.dateRange}</p>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed">{w.data.summary}</p>
        </a>
      ))}
    </div>
  )}
</Base>

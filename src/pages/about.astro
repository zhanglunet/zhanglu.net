---
import Base from '../layouts/Base.astro';
import SocialLinks from '../components/SocialLinks.astro';
import about from '../data/about.json';
---
<Base title="关于" description={about.bio}>
  <section class="py-6">
    <h1 class="font-serif text-3xl font-semibold mb-4">关于</h1>
    <p class="font-serif text-xl mb-4 leading-snug">{about.tagline}</p>
    <p class="text-[var(--color-ink)] leading-relaxed max-w-2xl mb-8">{about.bio}</p>
    <div class="mb-10 flex flex-wrap gap-2">
      {about.tags.map((t) => (
        <span class="text-xs px-2 py-1 bg-[var(--color-paper-2)] rounded font-mono">{t}</span>
      ))}
    </div>
    <div class="border-t border-[var(--color-rule)] pt-8">
      <h2 class="font-serif text-xl font-semibold mb-4">联系</h2>
      <SocialLinks />
    </div>
  </section>
</Base>
